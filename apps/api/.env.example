# Database
DATABASE_URL="postgresql://tisico:tisico_secret@localhost:5432/tisico?schema=public"

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# JWT (paso 2 - auth)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Seed admin (npm run prisma:seed -w apps/api)
SEED_ADMIN_EMAIL=admin@tisico.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_NAME=Gestión Tisico

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=tisico_minio
S3_SECRET_KEY=tisico_minio_secret
S3_BUCKET=tisico-uploads
S3_REGION=us-east-1
S3_USE_SSL=false

# URL pública de la web (links en correos)
APP_PUBLIC_URL=http://localhost:3000

# SMTP / Outlook — cuenta dedicada para hallazgos
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hallazgos@tu-dominio.com
SMTP_PASS=contraseña-o-app-password
SMTP_FROM=hallazgos@tu-dominio.com

# Correos genéricos en copia al crear hallazgos (separados por coma)
FINDINGS_DEFAULT_NOTIFICATION_EMAILS=seguridad@tu-dominio.com,gerencia@tu-dominio.com
