# Database
DATABASE_URL="postgresql://tisico:tisico_secret@localhost:5432/tisico?schema=public"

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# JWT (paso 2 - auth)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Seed admin (npm run prisma:seed -w apps/api)
SEED_ADMIN_EMAIL=admin@tisico.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_NAME=Administrador

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=tisico_minio
S3_SECRET_KEY=tisico_minio_secret
S3_BUCKET=tisico-uploads
S3_REGION=us-east-1
S3_USE_SSL=false
