generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OPERATOR
  SUPERVISOR
  ADMIN
}

enum FindingType {
  OBSERVACION
  NO_CONFORMIDAD
  INCIDENTE
  OPORTUNIDAD_MEJORA
}

enum FindingStatus {
  ABIERTO
  EN_TRATAMIENTO
  ACCION_PENDIENTE
  CERRADO
}

enum FindingPriority {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum ActionType {
  CORRECTIVA
  PREVENTIVA
}

enum CorrectiveActionStatus {
  PENDIENTE
  EN_CURSO
  COMPLETADA
  VENCIDA
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(OPERATOR)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  findingsReported       Finding[]              @relation("FindingsReported")
  findingsAssigned       Finding[]              @relation("FindingsAssigned")
  findingViewerEntries   FindingViewer[]
  findingAttachments     FindingAttachment[]
  findingNotes           FindingNote[]
  findingStatusChanges   FindingStatusHistory[]
  correctiveActionsOwned CorrectiveAction[]
  cieTaskReturns         CieTaskReturn[]

  @@map("users")
}

model Finding {
  id             String          @id @default(cuid())
  code           String          @unique
  type           FindingType
  status         FindingStatus   @default(ABIERTO)
  priority       FindingPriority @default(MEDIA)
  title          String
  description    String          @db.Text
  area           String?
  sector         String?
  locationDetail String?
  occurredAt     DateTime?
  typeDetails    Json            @default("{}")
  rootCause      String?         @db.Text
  rootCauseMeasures String?      @db.Text

  /// Datos del reportante (editables al cargar; no necesariamente el usuario logueado)
  reporterName     String
  reporterEmail    String
  reporterPosition String?

  /// Usuario del sistema que registró el hallazgo (auditoría)
  reporterId String
  reporter   User   @relation("FindingsReported", fields: [reporterId], references: [id])
  assigneeId String
  assignee   User   @relation("FindingsAssigned", fields: [assigneeId], references: [id])

  viewers              FindingViewer[]
  externalRecipients   FindingExternalRecipient[]
  attachments   FindingAttachment[]
  notes         FindingNote[]
  statusHistory FindingStatusHistory[]
  actions       CorrectiveAction[]
  fiveWhysSteps FiveWhysStep[]

  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([assigneeId])
  @@map("findings")
}

model FindingViewer {
  id        String  @id @default(cuid())
  findingId String
  finding   Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  @@unique([findingId, userId])
  @@map("finding_viewers")
}

model FindingExternalRecipient {
  id        String  @id @default(cuid())
  findingId String
  finding   Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  email     String
  name      String?

  @@unique([findingId, email])
  @@map("finding_external_recipients")
}

model FiveWhysStep {
  id        String   @id @default(cuid())
  findingId String
  finding   Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)
  level     Int
  question  String
  answer    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([findingId, level])
  @@map("five_whys_steps")
}

model CorrectiveAction {
  id            String                 @id @default(cuid())
  findingId     String
  finding       Finding                @relation(fields: [findingId], references: [id], onDelete: Cascade)
  type          ActionType
  description   String                 @db.Text
  dueDate       DateTime
  status        CorrectiveActionStatus @default(PENDIENTE)
  responsibleId String
  responsible   User                   @relation(fields: [responsibleId], references: [id])
  completedAt   DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([dueDate])
  @@map("corrective_actions")
}

model FindingAttachment {
  id           String   @id @default(cuid())
  findingId    String
  finding      Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)
  fileName     String
  fileKey      String
  mimeType     String
  sizeBytes    Int
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@map("finding_attachments")
}

model FindingNote {
  id        String   @id @default(cuid())
  findingId String
  finding   Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@map("finding_notes")
}

model FindingStatusHistory {
  id          String         @id @default(cuid())
  findingId   String
  finding     Finding        @relation(fields: [findingId], references: [id], onDelete: Cascade)
  fromStatus  FindingStatus?
  toStatus    FindingStatus
  comment     String?
  changedById String
  changedBy   User           @relation(fields: [changedById], references: [id])
  createdAt   DateTime       @default(now())

  @@map("finding_status_history")
}

// --- Módulo CIE (Calidad / Incendios) ---

enum CieWorkGroup {
  G1
  G2
}

enum CieActivityType {
  LIMPIEZA
  INSPECCION_VISUAL
  PRUEBA_ELEMENTOS
  CALIBRACION
}

enum CieReturnStatus {
  TERM
  CONT
  CANC
  FDM
  FMO
  INSP
  FCL
  SEG
  CTR
  EPT
  EDE
  FEM
  PGR
  IOOM
  IOOX
  IOOE
  IOOI
  PP0
  PLN
  CONM
  CONE
  CALC
  PTD
}

model CieScheduleConfig {
  id             String @id @default("default")
  horizonEndYear Int    @default(2028)

  @@map("cie_schedule_config")
}

model CieHoliday {
  id       String   @id @default(cuid())
  date     DateTime @db.Date
  name     String
  isBridge Boolean  @default(false)

  @@unique([date])
  @@map("cie_holidays")
}

model CieTaskTemplate {
  id               String            @id @default(cuid())
  workGroup        CieWorkGroup
  businessDayIndex Int
  sortOrder        Int
  programOrder     Int?
  workOrder        String?
  equipment        String?
  plant            String?
  description      String            @db.Text
  company          String            @default("TISICO FIRE&GAS")
  durationHours    Int               @default(4)
  activityTypes    CieActivityType[]

  scheduledTasks CieScheduledTask[]

  @@index([workGroup, businessDayIndex])
  @@map("cie_task_templates")
}

model CieScheduledTask {
  id                    String            @id @default(cuid())
  templateId            String?
  template              CieTaskTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  workGroup             CieWorkGroup
  scheduledDate         DateTime          @db.Date
  year                  Int
  month                 Int
  businessDayIndex      Int
  sortOrder             Int
  programOrder          Int?
  workOrder             String?
  equipment             String?
  plant                 String?
  description           String            @db.Text
  company               String            @default("TISICO FIRE&GAS")
  durationHours         Int
  activityTypes         CieActivityType[]
  isRescheduled         Boolean           @default(false)
  originalScheduledDate DateTime?         @db.Date
  rescheduleReason      String?

  returns CieTaskReturn[]

  @@index([workGroup, scheduledDate])
  @@index([year, month])
  @@map("cie_scheduled_tasks")
}

model CieTaskReturn {
  id              String          @id @default(cuid())
  scheduledTaskId String
  scheduledTask   CieScheduledTask @relation(fields: [scheduledTaskId], references: [id], onDelete: Cascade)
  returnDate      DateTime        @db.Date
  status          CieReturnStatus
  observations    String?         @db.Text
  submittedById   String
  submittedBy     User            @relation(fields: [submittedById], references: [id])
  submittedAt     DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([scheduledTaskId, returnDate])
  @@map("cie_task_returns")
}
